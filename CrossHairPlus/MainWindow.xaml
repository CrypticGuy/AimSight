<Window x:Class="CrossHairPlus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrossHair Plus - Settings"
        Height="700"
        Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e1e">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <!-- Dark Theme ComboBox with styled popup -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="#333333"
                                          BorderBrush="#555555"
                                          BorderThickness="1">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#333333" BorderBrush="#555555" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1" x:Name="Arrow" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0" Stroke="#ffffff" StrokeThickness="1"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="6,3,25,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PopupAnimation="Slide"
                                   Focusable="False">
                                <Border x:Name="DropDown"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#2a2a2a"
                                        BorderBrush="#555555"
                                        BorderThickness="1"
                                        Margin="0,2,0,0">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0078d4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078d4"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#0098ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Game Mode Section -->
            <Label Grid.Row="0" Content="Game Mode (In-Game Overlay)" FontWeight="Bold" Foreground="#00d4ff" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Process:" Foreground="#ffffff" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="GameProcessCombo" Width="180" Style="{StaticResource DarkComboBox}" SelectionChanged="OnGameProcessChanged"/>
                <Button x:Name="RefreshBtn" Content="Refresh" Width="60" Height="25" Margin="5,0,0,0" Click="OnRefreshGames"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="InjectBtn" Content="Inject" Width="70" Height="25" Margin="0,0,10,0" Click="OnInject" Style="{StaticResource PrimaryButton}" IsEnabled="False"/>
                <Button x:Name="UninjectBtn" Content="Uninject" Width="70" Height="25" Margin="0,0,10,0" Click="OnUninject" IsEnabled="False"/>
                <Label x:Name="InjectionStatusLabel" Content="Not injected" Foreground="#888888" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Separator -->
            <Separator Grid.Row="3" Background="#444444" Margin="0,5,0,15"/>

            <!-- Crosshair Type -->
            <Label Grid.Row="4" Content="Crosshair Type" Margin="0,0,0,5"/>
            <ComboBox x:Name="CrosshairTypeCombo" Grid.Row="5" Margin="0,0,0,15" Style="{StaticResource DarkComboBox}" SelectionChanged="OnSettingChanged">
                <ComboBoxItem Content="Dot"/>
                <ComboBoxItem Content="Cross"/>
                <ComboBoxItem Content="Circle"/>
                <ComboBoxItem Content="Cross + Circle"/>
            </ComboBox>

            <!-- Monitor Selection -->
            <Label Grid.Row="6" Content="Monitor (Desktop Mode)" Margin="0,0,0,5"/>
            <ComboBox x:Name="MonitorCombo" Grid.Row="7" Margin="0,0,0,15" Style="{StaticResource DarkComboBox}" SelectionChanged="OnMonitorChanged"/>

            <!-- Color Selection -->
            <Label Grid.Row="8" Content="Color" Margin="0,0,0,5"/>
            <StackPanel Grid.Row="9" Orientation="Horizontal" Margin="0,0,0,15">
                <Button x:Name="BtnRed" Width="35" Height="35" Margin="0,0,8,0" Click="OnColorClick" Tag="#FF0000" Background="#FF0000" BorderBrush="#666666" BorderThickness="2"/>
                <Button x:Name="BtnGreen" Width="35" Height="35" Margin="0,0,8,0" Click="OnColorClick" Tag="#00FF00" Background="#00FF00" BorderBrush="#666666" BorderThickness="2"/>
                <Button x:Name="BtnBlue" Width="35" Height="35" Margin="0,0,8,0" Click="OnColorClick" Tag="#0080FF" Background="#0080FF" BorderBrush="#666666" BorderThickness="2"/>
                <Button x:Name="BtnWhite" Width="35" Height="35" Margin="0,0,8,0" Click="OnColorClick" Tag="#FFFFFF" Background="#FFFFFF" BorderBrush="#666666" BorderThickness="2"/>
                <Button x:Name="BtnBlack" Width="35" Height="35" Margin="0,0,8,0" Click="OnColorClick" Tag="#000000" Background="#000000" BorderBrush="#666666" BorderThickness="2"/>
                <Button x:Name="BtnYellow" Width="35" Height="35" Click="OnColorClick" Tag="#FFFF00" Background="#FFFF00" BorderBrush="#666666" BorderThickness="2"/>
            </StackPanel>

            <!-- Size -->
            <Label Grid.Row="10" x:Name="SizeLabel" Content="Size: 40" Margin="0,0,0,5"/>
            <Slider x:Name="SizeSlider" Grid.Row="10" Minimum="10" Maximum="100" Value="40" Margin="0,20,0,10" ValueChanged="OnSettingChanged"/>

            <!-- Thickness -->
            <Label Grid.Row="10" x:Name="ThicknessLabel" Content="Thickness: 2" Margin="0,50,0,5"/>
            <Slider x:Name="ThicknessSlider" Grid.Row="10" Minimum="1" Maximum="10" Value="2" Margin="0,70,0,10" ValueChanged="OnSettingChanged"/>

            <!-- Offset X -->
            <Label Grid.Row="11" x:Name="OffsetXLabel" Content="Offset X: 0" Margin="0,0,0,5"/>
            <Slider x:Name="OffsetXSlider" Grid.Row="11" Minimum="-500" Maximum="500" Value="0" Margin="0,20,0,10" ValueChanged="OnSettingChanged"/>

            <!-- Offset Y -->
            <Label Grid.Row="11" x:Name="OffsetYLabel" Content="Offset Y: 0" Margin="0,50,0,5"/>
            <Slider x:Name="OffsetYSlider" Grid.Row="11" Minimum="-500" Maximum="500" Value="0" Margin="0,70,0,10" ValueChanged="OnSettingChanged"/>

            <!-- Preview -->
            <Border Grid.Row="12" BorderBrush="#555555" BorderThickness="1" Margin="0,10,0,0" HorizontalAlignment="Center" Width="80" Height="80" Background="#2a2a2a">
                <Canvas x:Name="PreviewCanvas" Width="80" Height="80"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Apply" Width="60" Height="30" Margin="0,0,10,0" Click="OnApply"/>
                <Button Content="Show/Hide" Width="80" Height="30" Margin="0,0,10,0" Click="OnToggleOverlay"/>
                <Button Content="Reset" Width="60" Height="30" Margin="0,0,10,0" Click="OnResetOffset"/>
                <Button Content="Close" Width="60" Height="30" Click="OnClose"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>